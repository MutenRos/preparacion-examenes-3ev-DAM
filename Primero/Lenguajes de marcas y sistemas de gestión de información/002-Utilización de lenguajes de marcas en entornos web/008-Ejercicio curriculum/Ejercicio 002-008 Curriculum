Ahora hacemos que nuestro archivo `HTML' cargue los datos desde el archivo `Curriculum.json` y los inserte en las secciones correspondientes utilizando JavaScript para mejorar la presentación visual del currículum con Flexbox.
```html
<!doctype html>
<html lang="es">
  <head>
    <title>Curriculum Dario Lacal Civera</title>
    <meta charset="utf-8">
    <style>
      * {
  margin: 0px;
  padding: 0px;
}
body, html {
  background: black;
  font-size: 11px;
}
main {
  width: 600px;
  background: white;
  margin: auto;
  display: flex;
  font-family: sans-serif;
}
#izquierda img {
  border-radius: 400px;
}
#izquierda {
  background: indigo;
  flex: 1;
  padding: 40px;
  color: white;
}
#derecha {
  flex: 3;
  padding: 40px;
}
#derecha article {
  border-bottom: 1px solid indigo;
}
#izquierda article {
  border-bottom: 1px solid white;
}
    </style>
  </head>
  <body>
    <main>
      <section id="izquierda">
      </section>
      <section id="derecha">
      </section>
    </main>
    <script>
      fetch('Curriculum.json')
        .then(response => response.json())
        .then(data => {
          const izquierda = document.getElementById('izquierda');
          const derecha = document.getElementById('derecha');

          // Datos personales
          izquierda.innerHTML += `<article><h3>${data.datos_personales.nombre} ${data.datos_personales.apellidos}</h3><p>${data.datos_personales.email}</p></article>`;

          // Redes sociales
          let redesHTML = '<article><h3>Redes Sociales</h3><ul>';
          data.redes_sociales.forEach(red => {
            const [key, value] = Object.entries(red)[0];
            redesHTML += `<li><a href="${value}">${key}</a></li>`;
          });
          redesHTML += '</ul></article>';
          izquierda.innerHTML += redesHTML;

          // Formación
          let formacionHTML = '<article><h2>Formación</h2>';
          data.formacion.forEach(formacion => {
            formacionHTML += `<h3>${formacion.titulo}</h3><p>${formacion.institucion} (${formacion.periodo})</p>`;
          });
          formacionHTML += '</article>';
          derecha.innerHTML += formacionHTML;

          // Experiencia laboral
          let experienciaHTML = '<article><h2>Experiencia Laboral</h2>';
          data.experiencia_laboral.forEach(experiencia => {
            experienciaHTML += `<h3>${experiencia.puesto}</h3><p>${experiencia.empresa} (${experiencia.periodo})</p>`;
          });
          experienciaHTML += '</article>';
          derecha.innerHTML += experienciaHTML;
        });
    </script>
  </body>
</html>
```
