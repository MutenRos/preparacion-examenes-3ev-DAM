### Desarrollo técnico correcto y preciso (25%)

#### Esquema XSD (esquema.xsd):

```xml
<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="persona">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="nombre" type="xs:string"/>
        <xs:element name="apellidos" type="xs:string"/>
        <xs:element name="edad" type="xs:integer"/>
        <xs:element name="email" type="xs:string"/>
        <xs:element name="ciudad" type="xs:string"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
```

#### Código Python (generar_xml.py):

```python
import xml.etree.ElementTree as ET
from xml.dom import minidom
import xmlschema

def generar_xml_desde_esquema(archivo_xsd, archivo_salida):
    """
    Genera un XML válido pidiendo datos al usuario según esquema XSD.
    
    Args:
        archivo_xsd: Ruta al esquema XSD
        archivo_salida: Ruta donde guardar el XML generado
    """
    # Cargar esquema XSD
    esquema = xmlschema.XMLSchema(archivo_xsd)
    
    # Obtener elemento raíz del esquema
    elemento_raiz = esquema.root_elements[0]
    nombre_raiz = elemento_raiz.local_name
    
    print(f"Generando XML según esquema: {archivo_xsd}\n")
    
    # Crear elemento raíz del XML
    raiz = ET.Element(nombre_raiz)
    
    # Obtener los campos del esquema
    campos = obtener_campos_esquema(elemento_raiz)
    
    # Solicitar valores al usuario para cada campo
    for campo in campos:
        nombre_campo = campo['nombre']
        tipo_campo = campo['tipo']
        
        valor = input(f"Introduce {nombre_campo} ({tipo_campo}): ")
        
        # Validar tipo de dato
        valor_validado = validar_tipo(valor, tipo_campo, nombre_campo)
        
        # Crear elemento hijo y añadirlo a la raíz
        elemento = ET.SubElement(raiz, nombre_campo)
        elemento.text = str(valor_validado)
    
    # Convertir a string y formatear
    xml_str = ET.tostring(raiz, encoding='utf-8')
    dom = minidom.parseString(xml_str)
    xml_formateado = dom.toprettyxml(indent="  ", encoding='UTF-8')
    
    # Guardar en archivo
    with open(archivo_salida, 'wb') as f:
        f.write(xml_formateado)
    
    print(f"\n✓ XML generado correctamente: {archivo_salida}")
    
    # Validar el XML generado
    try:
        esquema.validate(archivo_salida)
        print("✓ XML válido según el esquema XSD")
    except Exception as e:
        print(f"✗ Error de validación: {e}")

def obtener_campos_esquema(elemento):
    """Extrae los campos del esquema XSD"""
    campos = []
    
    # Navegar por el tipo complejo
    if hasattr(elemento, 'type'):
        tipo = elemento.type
        if hasattr(tipo, 'content'):
            for item in tipo.content:
                if hasattr(item, 'local_name'):
                    campos.append({
                        'nombre': item.local_name,
                        'tipo': obtener_tipo_base(item)
                    })
    
    return campos

def obtener_tipo_base(elemento):
    """Obtiene el tipo base de un elemento XSD"""
    if hasattr(elemento, 'type'):
        tipo = elemento.type
        if hasattr(tipo, 'local_name'):
            return tipo.local_name
        elif hasattr(tipo, 'base_type'):
            return tipo.base_type.local_name
    return 'string'

def validar_tipo(valor, tipo, nombre_campo):
    """Valida y convierte el valor según el tipo XSD"""
    try:
        if tipo == 'integer':
            return int(valor)
        elif tipo == 'decimal' or tipo == 'float':
            return float(valor)
        elif tipo == 'boolean':
            return valor.lower() in ['true', '1', 'yes', 'sí']
        else:
            return valor
    except ValueError:
        print(f"⚠ Advertencia: '{valor}' no es un {tipo} válido para {nombre_campo}")
        return valor

# Ejecutar generación
if __name__ == "__main__":
    generar_xml_desde_esquema('esquema.xsd', 'persona.xml')
```

