#### Versión simplificada (sin dependencias externas):

```python
import xml.etree.ElementTree as ET
from xml.dom import minidom

def generar_xml_simple():
    """Genera XML sin parsear XSD (versión simplificada)"""
    
    # Crear elemento raíz
    raiz = ET.Element('persona')
    
    # Campos predefinidos
    campos = ['nombre', 'apellidos', 'edad', 'email', 'ciudad']
    
    print("Generación de XML - Persona\n")
    
    # Solicitar valores
    for campo in campos:
        valor = input(f"Introduce {campo}: ")
        elemento = ET.SubElement(raiz, campo)
        elemento.text = valor
    
    # Formatear XML
    xml_str = ET.tostring(raiz, encoding='utf-8')
    dom = minidom.parseString(xml_str)
    xml_formateado = dom.toprettyxml(indent="  ", encoding='UTF-8')
    
    # Guardar
    with open('persona.xml', 'wb') as f:
        f.write(xml_formateado)
    
    print("\n✓ XML generado: persona.xml")

if __name__ == "__main__":
    generar_xml_simple()
```

#### Ejemplo con valores por defecto:

```python
def generar_xml_con_defaults():
    """Genera XML con valores por defecto"""
    
    datos_default = {
        'nombre': 'Dario',
        'apellidos': 'Lacal Civera',
        'edad': '22',
        'email': 'dario@example.com',
        'ciudad': 'Valencia'
    }
    
    raiz = ET.Element('persona')
    
    for campo, default in datos_default.items():
        valor = input(f"{campo} [{default}]: ") or default
        elemento = ET.SubElement(raiz, campo)
        elemento.text = valor
    
    # Formatear y guardar
    xml_str = ET.tostring(raiz, encoding='utf-8')
    dom = minidom.parseString(xml_str)
    
    with open('persona.xml', 'wb') as f:
        f.write(dom.toprettyxml(indent="  ", encoding='UTF-8'))
    
    print("✓ XML generado correctamente")

generar_xml_con_defaults()
```

