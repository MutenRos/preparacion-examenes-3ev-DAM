from flask import Flask, render_template

aplicacion = Flask(__name__)

# Catálogo de productos (normalmente vendría de BD)
productos = [
    {
        "id": 1,
        "nombre": "Raspberry Pi 4 8GB",
        "descripcion": "Microordenador completo",
        "precio": 89.99,
        "imagen": "https://via.placeholder.com/200x150/667eea/ffffff?text=Pi+4"
    },
    {
        "id": 2,
        "nombre": "Carcasa impresa 3D",
        "descripcion": "Personalizada con ventilación",
        "precio": 12.50,
        "imagen": "https://via.placeholder.com/200x150/764ba2/ffffff?text=Case+3D"
    },
    {
        "id": 3,
        "nombre": "Filamento PLA 1kg",
        "descripcion": "Color negro mate",
        "precio": 18.99,
        "imagen": "https://via.placeholder.com/200x150/3498db/ffffff?text=Filamento"
    },
    {
        "id": 4,
        "nombre": "Sensor DHT22",
        "descripcion": "Temperatura y humedad",
        "precio": 5.99,
        "imagen": "https://via.placeholder.com/200x150/e74c3c/ffffff?text=Sensor"
    },
    {
        "id": 5,
        "nombre": "Cable HDMI 2m",
        "descripcion": "4K 60Hz compatible",
        "precio": 7.50,
        "imagen": "https://via.placeholder.com/200x150/2ecc71/ffffff?text=HDMI"
    },
    {
        "id": 6,
        "nombre": "Kit LEDs RGB",
        "descripcion": "WS2812B 5 metros",
        "precio": 15.99,
        "imagen": "https://via.placeholder.com/200x150/f39c12/ffffff?text=LEDs"
    }
]

@aplicacion.route("/")
def raiz():
    return render_template("index.html", productos=productos)

@aplicacion.route("/producto/<int:id>")
def detalle_producto(id):
    producto = next((p for p in productos if p["id"] == id), None)
    if producto:
        return f'''
        <h1>{producto["nombre"]}</h1>
        <img src="{producto["imagen"]}" style="max-width:400px">
        <p>{producto["descripcion"]}</p>
        <h2>{producto["precio"]}€</h2>
        <a href="/">Volver a la tienda</a>
        '''
    return "Producto no encontrado", 404

if __name__ == "__main__":
    aplicacion.run(host="0.0.0.0", port=5000, debug=True)

