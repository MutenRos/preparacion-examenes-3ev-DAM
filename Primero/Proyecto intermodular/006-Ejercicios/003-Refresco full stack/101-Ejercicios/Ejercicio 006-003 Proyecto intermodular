# 1. Integración con SQLite
import sqlite3

def obtener_productos():
    conn = sqlite3.connect('tienda.db')
    cursor = conn.cursor()
    cursor.execute("SELECT * FROM productos")
    productos = cursor.fetchall()
    conn.close()
    return productos

# 2. Carrito de compras (sesiones)
from flask import session

@aplicacion.route("/agregar/<int:id>")
def agregar_carrito(id):
    if 'carrito' not in session:
        session['carrito'] = []
    session['carrito'].append(id)
    return f"Producto {id} agregado al carrito"

# 3. Búsqueda de productos
@aplicacion.route("/buscar")
def buscar():
    query = request.args.get('q', '')
    resultados = [p for p in productos if query.lower() in p['nombre'].lower()]
    return render_template("index.html", productos=resultados)

