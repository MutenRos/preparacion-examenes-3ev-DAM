from flask import Flask
import sqlite3

aplicacion = Flask(__name__)

@aplicacion.route("/")
def blog():
    # Conectar y recuperar artículos
    base_de_datos = "blog.db"
    conexion = sqlite3.connect(base_de_datos)
    cursor = conexion.cursor()
    cursor.execute("SELECT * FROM articulos ORDER BY fecha DESC")
    articulos_recuperados = cursor.fetchall()
    conexion.close()
    
    # Generar HTML
    html = '''
    <!DOCTYPE html>
    <html lang="es">
    <head>
        <meta charset="UTF-8">
