INTRODUCCIÓN
------------
Este ejercicio conecta programación Python con bases de datos SQLite para gestionar un blog de proyectos 3D. SQLite es ideal para aplicaciones pequeñas/medianas: no requiere servidor, archivo único portable, perfecto para Raspberry Pi.

PASO 1: CREAR BASE DE DATOS Y TABLA
------------------------------------

import sqlite3

# Crear base de datos y tabla (solo primera vez)
base_de_datos = "blog.db"
conexion = sqlite3.connect(base_de_datos)
cursor = conexion.cursor()

cursor.execute('''
CREATE TABLE IF NOT EXISTS articulos (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    titulo TEXT NOT NULL,
    fecha TEXT NOT NULL,
    texto TEXT,
    imagen TEXT
)
''')

# Insertar datos de ejemplo (proyectos 3D)
articulos_ejemplo = [
    ("Carcasa Raspberry Pi 4", "2025-11-01", "Diseño modular con ventilación optimizada", "raspberry_case.jpg"),
    ("Soporte monitor ergonómico", "2025-11-05", "Ajustable en altura y ángulo", "monitor_stand.jpg"),
    ("Organizador cables escritorio", "2025-11-08", "Sistema modular con clips magnéticos", "cable_organizer.jpg")
]

cursor.executemany(
    "INSERT INTO articulos (titulo, fecha, texto, imagen) VALUES (?, ?, ?, ?)",
    articulos_ejemplo
)

conexion.commit()
conexion.close()
print("Base de datos creada con éxito")

