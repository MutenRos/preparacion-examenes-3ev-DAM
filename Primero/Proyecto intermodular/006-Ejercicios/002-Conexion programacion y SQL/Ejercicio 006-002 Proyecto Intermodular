import sqlite3

def conectar():
    return sqlite3.connect("blog.db")

# CREATE
def crear_articulo(titulo, fecha, texto, imagen):
    conexion = conectar()
    cursor = conexion.cursor()
    cursor.execute(
        "INSERT INTO articulos (titulo, fecha, texto, imagen) VALUES (?, ?, ?, ?)",
        (titulo, fecha, texto, imagen)
    )
    conexion.commit()
    conexion.close()
    print(f"Artículo '{titulo}' creado")

# READ
def listar_articulos():
    conexion = conectar()
    cursor = conexion.cursor()
    cursor.execute("SELECT * FROM articulos")
    articulos = cursor.fetchall()
    conexion.close()
    return articulos

# UPDATE
def actualizar_articulo(id, titulo, fecha, texto, imagen):
    conexion = conectar()
    cursor = conexion.cursor()
    cursor.execute(
        "UPDATE articulos SET titulo=?, fecha=?, texto=?, imagen=? WHERE id=?",
        (titulo, fecha, texto, imagen, id)
    )
    conexion.commit()
    conexion.close()
    print(f"Artículo ID {id} actualizado")

# DELETE
def eliminar_articulo(id):
    conexion = conectar()
    cursor = conexion.cursor()
    cursor.execute("DELETE FROM articulos WHERE id=?", (id,))
    conexion.commit()
    conexion.close()
    print(f"Artículo ID {id} eliminado")

# Ejemplo de uso
if __name__ == "__main__":
    # Crear nuevo artículo
    crear_articulo(
        "Miniaturas Warhammer", 
        "2025-11-10", 
        "Impresión de ejército completo con resina",
        "warhammer.jpg"
    )
    
    # Listar todos
    articulos = listar_articulos()
    for a in articulos:
        print(f"{a[0]}: {a[1]} ({a[2]})")
    
    # Actualizar artículo ID 1
