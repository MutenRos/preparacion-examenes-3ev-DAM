# Alternativa: Tablero de juego estilo miniatura gaming

@aplicacion.route('/tablero')
def tablero():
    html = '''
    <!DOCTYPE html>
    <html>
    <head>
        <title>Tablero Gaming 8x8</title>
        <style>
            body {
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                background: #2c3e50;
            }
            
            .board {
                display: grid;
                grid-template-columns: repeat(8, 60px);
                grid-template-rows: repeat(8, 60px);
                gap: 0;
                border: 5px solid #34495e;
                box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            }
            
            .cell {
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2em;
                cursor: pointer;
                transition: all 0.2s;
            }
            
            .cell:hover {
                transform: scale(1.1);
                z-index: 10;
            }
            
            .white { background: #f0d9b5; }
            .black { background: #b58863; }
        </style>
    </head>
    <body>
        <div class="board">
    '''
    
    # Generar tablero 8x8 alternando colores
    for row in range(8):
        for col in range(8):
            color = 'white' if (row + col) % 2 == 0 else 'black'
            coord = f'{chr(65+col)}{8-row}'  # A8, B8, ..., H1
            html += f'<div class="cell {color}">{coord}</div>'
    
    html += '''
        </div>
    </body>
    </html>
    '''
    
    return html

