CÓDIGO PYTHON - app.py
================================================================================

from flask import Flask
import calendar

aplicacion = Flask(__name__)

@aplicacion.route('/')
def raiz():
    # Generar año completo 2025
    year = 2025
    
    html = '''
    <!DOCTYPE html>
    <html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Calendario 3D Printing Schedule</title>
        <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            
            body {
                font-family: 'Arial', sans-serif;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                padding: 20px;
                min-height: 100vh;
            }
            
            h1 {
                text-align: center;
                color: white;
                margin-bottom: 30px;
                font-size: 2.5em;
                text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            }
            
            .year-container {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 20px;
                max-width: 1400px;
                margin: 0 auto;
            }
            
            .month-container {
                background: white;
                border-radius: 15px;
                padding: 20px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.2);
                transition: transform 0.3s;
            }
            
            .month-container:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 40px rgba(0,0,0,0.3);
            }
            
            .month-name {
                text-align: center;
                font-size: 1.5em;
                font-weight: bold;
                color: #667eea;
                margin-bottom: 15px;
                padding-bottom: 10px;
                border-bottom: 3px solid #f0f0f0;
            }
            
            .calendar-grid {
                display: grid;
                grid-template-columns: repeat(7, 1fr);
                gap: 5px;
            }
            
            .day-header {
                text-align: center;
                font-weight: bold;
                color: #764ba2;
                padding: 10px 5px;
                font-size: 0.9em;
                background: #f8f9fa;
                border-radius: 5px;
            }
            
            .day-cell {
                aspect-ratio: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                border: 2px solid #e0e0e0;
                border-radius: 8px;
                font-weight: 500;
                cursor: pointer;
                transition: all 0.2s;
                background: white;
            }
            
            .day-cell:hover {
                background: #667eea;
                color: white;
                border-color: #667eea;
                transform: scale(1.1);
            }
            
            .empty-cell {
                background: transparent;
                border: none;
            }
            
            .weekend {
                background: #fff3cd;
            }
            
            .today {
                background: #28a745;
                color: white;
                border-color: #28a745;
                font-weight: bold;
            }
            
            @media (max-width: 768px) {
                .year-container {
                    grid-template-columns: 1fr;
                }
                
                h1 {
                    font-size: 1.8em;
                }
            }
        </style>
    </head>
    <body>
        <h1>📅 Calendario Proyectos 3D - 2025</h1>
        <div class="year-container">
    '''
    
    # Nombres de meses en español
    meses = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
             'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre']
    
    # Días de la semana
    dias_semana = ['L', 'M', 'X', 'J', 'V', 'S', 'D']
    
    # Generar cada mes
    for month_num in range(1, 13):
        html += '<div class="month-container">'
        html += f'<div class="month-name">{meses[month_num - 1]}</div>'
        html += '<div class="calendar-grid">'
        
        # Headers de días de la semana
        for day in dias_semana:
            html += f'<div class="day-header">{day}</div>'
        
        # Obtener calendario del mes
        month_calendar = calendar.monthcalendar(year, month_num)
        
        # Generar celdas de días
        for week in month_calendar:
            for day_num, day in enumerate(week):
                if day == 0:
                    # Celda vacía
                    html += '<div class="day-cell empty-cell"></div>'
                else:
                    # Determinar si es fin de semana (sábado=5, domingo=6)
                    weekend_class = 'weekend' if day_num >= 5 else ''
                    
                    # Marcar día actual (ejemplo: 8 de noviembre)
                    today_class = 'today' if month_num == 11 and day == 8 else ''
                    
                    html += f'<div class="day-cell {weekend_class} {today_class}">{day}</div>'
        
        html += '</div>'  # Cierra calendar-grid
        html += '</div>'  # Cierra month-container
    
    html += '''
        </div>
    </body>
    </html>
    '''
    
    return html

# Ejecutar aplicación
if __name__ == '__main__':
    aplicacion.run(host='0.0.0.0', port=5000, debug=True)

